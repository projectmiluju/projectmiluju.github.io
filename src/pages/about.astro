---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="About"
  description="백엔드/인프라 중심의 풀스택 엔지니어. 신뢰성, 성능, 자동화를 추구합니다."
>
  <div class="about-page">
    <div class="container">

      <!-- ══ Identity Terminal ══ -->
      <header class="identity-section reveal">
        <div class="terminal-window identity-terminal">
          <div class="terminal-titlebar">
            <div class="terminal-dots">
              <span class="terminal-dot dot-close"></span>
              <span class="terminal-dot dot-minimize"></span>
              <span class="terminal-dot dot-maximize"></span>
            </div>
            <span class="terminal-title">about.txt — {siteConfig.name}@portfolio</span>
            <span class="terminal-title-right">bash</span>
          </div>
          <div class="identity-body">
            <!-- Profile image col -->
            <div class="profile-col">
              <div class="profile-frame">
                <img
                  src="/images/profile.png"
                  alt="Profile"
                  class="profile-img"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                />
                <div class="profile-placeholder" aria-hidden="true">
                  <span class="placeholder-ascii">[ ? ]</span>
                </div>
              </div>
              <div class="profile-links">
                <a href={siteConfig.links.github} class="profile-link" target="_blank" rel="noopener noreferrer">
                  [github]
                </a>
                <a href={`mailto:${siteConfig.author.email}`} class="profile-link">
                  [email]
                </a>
              </div>
            </div>

            <!-- Info col -->
            <div class="info-col">
              <div class="info-cmd">
                <span class="p-dollar">$ </span><span class="p-cmd">cat about.txt</span>
              </div>
              <div class="info-fields">
                <div class="info-row">
                  <span class="field-key">name   </span>
                  <span class="field-sep">: </span>
                  <span class="field-val field-bright">정원용</span>
                </div>
                <div class="info-row">
                  <span class="field-key">role   </span>
                  <span class="field-sep">: </span>
                  <span class="field-val field-accent">Backend/Infra 중심 풀스택 엔지니어</span>
                </div>
                <div class="info-row">
                  <span class="field-key">email  </span>
                  <span class="field-sep">: </span>
                  <a href={`mailto:${siteConfig.author.email}`} class="field-val field-link">{siteConfig.author.email}</a>
                </div>
                <div class="info-row">
                  <span class="field-key">github </span>
                  <span class="field-sep">: </span>
                  <a href={siteConfig.links.github} class="field-val field-link" target="_blank" rel="noopener noreferrer">github.com/projectmiluju</a>
                </div>
                <div class="info-divider">──────────────────────────────────────</div>
                <div class="info-bio">
                  <p><span class="bio-prefix">&gt; </span>복잡한 문제를 단순하게 해결하고,</p>
                  <p><span class="bio-prefix">&gt; </span>자동화를 통해 팀의 생산성을 높입니다.</p>
                  <p><span class="bio-prefix">&gt; </span>사용자에게 가치를 전달하는 전체 과정을 이해하고</p>
                  <p><span class="bio-prefix">&gt; </span>기여할 수 있는 엔지니어를 지향합니다.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- ══ Content Grid ══ -->
      <div class="content-grid">

        <!-- 경력 -->
        <div class="term-card reveal stagger-1">
          <div class="card-titlebar">
            <span class="card-cmd">$ cat experience.log</span>
            <span class="card-file">experience.log</span>
          </div>
          <div class="card-body">
            <div class="exp-entry">
              <div class="exp-header-row">
                <span class="exp-period">[2025.11 – 2025.12]</span>
                <span class="exp-company">(주)더헤르츠</span>
              </div>
              <div class="exp-role">
                <span class="field-key">role</span>
                <span class="field-sep"> : </span>
                <span class="field-accent">Fullstack Engineer</span>
              </div>
              <ul class="exp-list">
                <li><span class="li-arrow">·</span> Next.js 기반 통합 브랜드 웹 플랫폼 구축</li>
                <li><span class="li-arrow">·</span> AWS (S3, CloudFront) 배포 인프라 구축</li>
                <li><span class="li-arrow">·</span> GitHub Actions CI/CD 자동화</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 학력 -->
        <div class="term-card reveal stagger-2">
          <div class="card-titlebar">
            <span class="card-cmd">$ cat education.txt</span>
            <span class="card-file">education.txt</span>
          </div>
          <div class="card-body">
            <div class="edu-entry">
              <div class="edu-period">[2025.03 – 2025.09]</div>
              <div class="edu-name">Kakao x goorm DEEP DIVE <span class="edu-badge">우수수료</span></div>
              <div class="edu-detail">풀스택 개발자 과정 13기</div>
            </div>
            <div class="edu-sep">──────────────</div>
            <div class="edu-entry">
              <div class="edu-period">[2025.03 – 2026.08]</div>
              <div class="edu-name">학점은행제</div>
              <div class="edu-detail">컴퓨터공학과 학사 수료예정</div>
            </div>
            <div class="edu-sep">──────────────</div>
            <div class="edu-entry">
              <div class="edu-period">[2013.03 – 2021.08]</div>
              <div class="edu-name">인하대학교</div>
              <div class="edu-detail">산업경영공학과 학사</div>
            </div>
          </div>
        </div>

        <!-- 기술 스택 (full width) -->
        <div class="term-card term-card-full reveal stagger-3">
          <div class="card-titlebar">
            <span class="card-cmd">$ ls -la skills/</span>
            <span class="card-file">skills/</span>
          </div>
          <div class="card-body skills-body">
            <div class="skill-group">
              <div class="skill-group-name">Backend/</div>
              <div class="skill-tags">
                <span class="skill-tag skill-primary">Java</span>
                <span class="skill-tag skill-primary">Spring Boot</span>
                <span class="skill-tag">JPA</span>
                <span class="skill-tag">Node.js</span>
                <span class="skill-tag">TypeScript</span>
              </div>
            </div>
            <div class="skill-group">
              <div class="skill-group-name">Infra/</div>
              <div class="skill-tags">
                <span class="skill-tag skill-primary">AWS</span>
                <span class="skill-tag skill-primary">Docker</span>
                <span class="skill-tag">Kubernetes</span>
                <span class="skill-tag">GitHub Actions</span>
                <span class="skill-tag">Terraform</span>
              </div>
            </div>
            <div class="skill-group">
              <div class="skill-group-name">Database/</div>
              <div class="skill-tags">
                <span class="skill-tag skill-primary">PostgreSQL</span>
                <span class="skill-tag skill-primary">MySQL</span>
                <span class="skill-tag">Redis</span>
                <span class="skill-tag">MongoDB</span>
              </div>
            </div>
            <div class="skill-group">
              <div class="skill-group-name">Frontend/</div>
              <div class="skill-tags">
                <span class="skill-tag skill-primary">React</span>
                <span class="skill-tag skill-primary">Next.js</span>
                <span class="skill-tag">TypeScript</span>
                <span class="skill-tag">Vite</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 가치관 -->
        <div class="term-card reveal stagger-4">
          <div class="card-titlebar">
            <span class="card-cmd">$ cat values.md</span>
            <span class="card-file">values.md</span>
          </div>
          <div class="card-body">
            <div class="values-list">
              <div class="value-row">
                <span class="val-check">✓</span>
                <div class="val-content">
                  <span class="val-title">단순함을 추구</span>
                  <span class="val-desc">복잡한 문제를 단순하게 해결하는 것이 좋은 엔지니어링</span>
                </div>
              </div>
              <div class="value-row">
                <span class="val-check">✓</span>
                <div class="val-content">
                  <span class="val-title">데이터로 판단</span>
                  <span class="val-desc">감보다는 측정과 분석을 통해 의사결정</span>
                </div>
              </div>
              <div class="value-row">
                <span class="val-check">✓</span>
                <div class="val-content">
                  <span class="val-title">자동화를 사랑</span>
                  <span class="val-desc">반복 작업을 줄이고 창의적인 일에 집중</span>
                </div>
              </div>
              <div class="value-row">
                <span class="val-check">✓</span>
                <div class="val-content">
                  <span class="val-title">함께 성장</span>
                  <span class="val-desc">지식을 공유하고 팀 전체가 발전하는 환경</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 일하는 방식 -->
        <div class="term-card reveal stagger-5">
          <div class="card-titlebar">
            <span class="card-cmd">$ cat work-style.md</span>
            <span class="card-file">work-style.md</span>
          </div>
          <div class="card-body">
            <ul class="work-list">
              <li><span class="li-arrow">→</span> 문제의 본질을 먼저 파악하고 효과적인 해결책을 찾습니다</li>
              <li><span class="li-arrow">→</span> 코드 리뷰를 통해 지식을 공유하고 품질을 높입니다</li>
              <li><span class="li-arrow">→</span> 문서화와 기록을 중요하게 생각합니다</li>
              <li><span class="li-arrow">→</span> 작은 단위로 자주 배포하고 빠르게 피드백을 반영합니다</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: calc(var(--header-height) + var(--space-10)) 0 var(--space-20);
    font-family: var(--font-mono);
  }

  /* ── Identity Terminal ── */
  .identity-section {
    margin-bottom: var(--space-8);
  }

  .identity-terminal {
    overflow: hidden;
  }

  .terminal-window {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dots {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-close    { background-color: #ff5f57; }
  .dot-minimize { background-color: #febc2e; }
  .dot-maximize { background-color: #28c840; }

  .terminal-title {
    flex: 1;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
  }

  .terminal-title-right {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    flex-shrink: 0;
  }

  .identity-body {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0;
  }

  /* Profile column */
  .profile-col {
    padding: var(--space-6) var(--space-6) var(--space-6) var(--space-5);
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .profile-frame {
    width: 100px;
    height: 100px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
    background-color: var(--color-bg-elevated);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
  }

  .profile-placeholder {
    display: none;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
  }

  .placeholder-ascii {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .profile-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }

  .profile-link {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .profile-link:hover {
    color: var(--color-accent);
  }

  /* Info column */
  .info-col {
    padding: var(--space-5) var(--space-6);
  }

  .info-cmd {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .p-dollar { color: var(--color-accent); }
  .p-cmd { color: var(--color-text-muted); }

  .info-fields {
    font-size: var(--text-sm);
    line-height: 1.9;
  }

  .info-row {
    display: flex;
    align-items: baseline;
    gap: 0;
  }

  .field-key {
    color: var(--color-prompt-path);
    white-space: pre;
    flex-shrink: 0;
  }

  .field-sep {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .field-val {
    color: var(--color-text);
  }

  .field-bright {
    color: var(--color-text-bright);
    font-weight: 600;
    font-size: var(--text-lg);
  }

  .field-accent {
    color: var(--color-accent);
  }

  .field-link {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .field-link:hover {
    color: var(--color-accent);
  }

  .info-divider {
    color: var(--color-text-dim);
    margin: var(--space-3) 0;
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
  }

  .info-bio {
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .info-bio p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .bio-prefix {
    color: var(--color-text-dim);
  }

  /* ── Content Grid ── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .term-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .term-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  .term-card-full {
    grid-column: span 2;
  }

  .card-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .card-cmd {
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .card-file {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .card-body {
    padding: var(--space-5) var(--space-4);
    font-size: var(--text-sm);
  }

  /* Experience */
  .exp-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .exp-header-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .exp-period {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .exp-company {
    color: var(--color-text-bright);
    font-weight: 600;
  }

  .exp-role {
    font-size: var(--text-xs);
    display: flex;
    align-items: baseline;
  }

  .field-accent { color: var(--color-accent); }

  .exp-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .exp-list li {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-2);
    line-height: 1.6;
  }

  .li-arrow {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Education */
  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .edu-period {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .edu-name {
    color: var(--color-text-bright);
    font-weight: 600;
  }

  .edu-detail {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .edu-badge {
    font-size: var(--text-xs);
    color: var(--color-accent);
    border: 1px solid rgba(0, 255, 65, 0.3);
    background-color: var(--color-accent-light);
    border-radius: var(--radius-sm);
    padding: 0 0.4em;
    margin-left: var(--space-2);
    font-weight: 500;
    vertical-align: middle;
  }

  .edu-sep {
    color: var(--color-text-dim);
    font-size: var(--text-xs);
    margin: var(--space-3) 0;
  }

  /* Skills */
  .skills-body {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .skill-group-name {
    font-size: var(--text-xs);
    color: var(--color-prompt-path);
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .skill-tag {
    font-size: var(--text-xs);
    padding: 0.1em 0.5em;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
  }

  .skill-primary {
    border-color: rgba(0, 255, 65, 0.2);
    color: var(--color-accent);
    background-color: var(--color-accent-light);
  }

  /* Values */
  .values-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .value-row {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    align-items: flex-start;
  }

  .value-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .value-row:first-child {
    padding-top: 0;
  }

  .val-check {
    color: var(--color-accent);
    flex-shrink: 0;
    font-size: var(--text-sm);
    margin-top: 1px;
  }

  .val-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .val-title {
    color: var(--color-text-bright);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .val-desc {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    line-height: 1.6;
  }

  /* Work style */
  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .work-list li {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .work-list .li-arrow {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .skills-body {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: calc(var(--header-height) + var(--space-6));
    }

    .identity-body {
      grid-template-columns: 1fr;
    }

    .profile-col {
      flex-direction: row;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-4);
    }

    .profile-frame {
      width: 72px;
      height: 72px;
    }

    .profile-links {
      flex-direction: row;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .term-card-full {
      grid-column: span 1;
    }

    .skills-body {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
