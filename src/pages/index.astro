---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import StrengthCard from '../components/StrengthCard.astro';
import { siteConfig } from '../config/site';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);

const allProjects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.order - a.data.order);

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, 3);

// Data to pass to the interactive terminal script
const projectsData = allProjects.map(p => ({
  title: p.data.title,
  slug: p.slug,
  role: p.data.role,
}));

const postsData = allPosts.slice(0, 8).map(p => ({
  title: p.data.title,
  slug: p.slug,
  category: p.data.category,
}));
---

<BaseLayout>
  <!-- ══ HERO: Terminal Window ══ -->
  <section class="hero">
    <div class="container">
      <div class="terminal-window hero-terminal" id="hero-terminal-window">
        <!-- Title bar -->
        <div class="terminal-titlebar">
          <div class="terminal-dots">
            <span class="terminal-dot dot-close"></span>
            <span class="terminal-dot dot-minimize"></span>
            <span class="terminal-dot dot-maximize"></span>
          </div>
          <span class="terminal-title">{siteConfig.name}@portfolio: ~</span>
          <span class="terminal-title-right">bash</span>
        </div>

        <!-- Terminal body -->
        <div class="terminal-body" id="hero-terminal">

          <!-- Line 1: whoami -->
          <div class="t-line" id="t-line-1">
            <span class="t-prompt">
              <span class="p-user">{siteConfig.name}</span><span class="p-at">@</span><span class="p-host">portfolio</span><span class="p-colon">:</span><span class="p-path">~</span><span class="p-dollar">$ </span>
            </span>
            <span class="t-cmd" id="t-cmd-1"></span>
          </div>
          <div class="t-output-block" id="t-out-1" hidden>
            <p class="t-out t-out-bright">풀스택 엔지니어 · AI 프로덕트 빌더</p>
          </div>

          <!-- Line 2: cat profile.txt -->
          <div class="t-line" id="t-line-2" hidden>
            <span class="t-prompt">
              <span class="p-user">{siteConfig.name}</span><span class="p-at">@</span><span class="p-host">portfolio</span><span class="p-colon">:</span><span class="p-path">~</span><span class="p-dollar">$ </span>
            </span>
            <span class="t-cmd" id="t-cmd-2"></span>
          </div>
          <div class="t-output-block" id="t-out-2" hidden>
            <p class="t-out">백엔드/인프라에 뿌리를 두고, AI 통합부터 프론트엔드까지 혼자 설계합니다.</p>
            <p class="t-out">복잡한 시스템을 처음부터 끝까지 직접 만들어야 제대로 이해한다고 믿습니다.</p>
          </div>

          <!-- Line 3: ls skills/ -->
          <div class="t-line" id="t-line-3" hidden>
            <span class="t-prompt">
              <span class="p-user">{siteConfig.name}</span><span class="p-at">@</span><span class="p-host">portfolio</span><span class="p-colon">:</span><span class="p-path">~</span><span class="p-dollar">$ </span>
            </span>
            <span class="t-cmd" id="t-cmd-3"></span>
          </div>
          <div class="t-output-block t-skills" id="t-out-3" hidden>
            <span class="t-skill">Kotlin</span>
            <span class="t-skill">Spring Boot</span>
            <span class="t-skill">Java</span>
            <span class="t-skill">Python</span>
            <span class="t-skill">FastAPI</span>
            <span class="t-skill">LangGraph</span>
            <span class="t-skill">RAG</span>
            <span class="t-skill">Next.js</span>
            <span class="t-skill">React</span>
            <span class="t-skill">TypeScript</span>
            <span class="t-skill">AWS</span>
            <span class="t-skill">Kubernetes</span>
            <span class="t-skill">Terraform</span>
            <span class="t-skill">Docker</span>
            <span class="t-skill">PostgreSQL</span>
            <span class="t-skill">Redis</span>
            <span class="t-skill">Kafka</span>
          </div>

          <!-- Interactive input line (shown after typewriter) -->
          <div class="t-line" id="t-line-final" hidden>
            <span class="t-prompt">
              <span class="p-user">{siteConfig.name}</span><span class="p-at">@</span><span class="p-host">portfolio</span><span class="p-colon">:</span><span class="p-path">~</span><span class="p-dollar">$ </span>
            </span>
            <span id="t-typed" class="t-cmd"></span><span class="cursor" aria-hidden="true"></span>
          </div>

        </div>

        <!-- Hint bar -->
        <div class="terminal-hint" id="terminal-hint" hidden>
          <span>⌨ type <strong>help</strong> to see available commands</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="hero-actions reveal">
        <a href="/projects" class="term-btn">
          <span class="btn-bracket">[</span>cd /projects<span class="btn-bracket">]</span>
        </a>
        <a href={`mailto:${siteConfig.author.email}`} class="term-btn term-btn-ghost">
          <span class="btn-bracket">[</span>mail --open<span class="btn-bracket">]</span>
        </a>
        <a href={siteConfig.links.github} class="term-btn term-btn-ghost" target="_blank" rel="noopener noreferrer">
          <span class="btn-bracket">[</span>github --profile<span class="btn-bracket">]</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══ STRENGTHS ══ -->
  <section class="section strengths">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-cmd">$ ./check_skills.sh</span>
        <span class="section-status">running diagnostics...</span>
      </div>
      <div class="strengths-grid">
        {siteConfig.strengths.map((strength, index) => (
          <div class={`reveal stagger-${index + 1}`}>
            <StrengthCard {...strength} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ PROJECTS ══ -->
  <section class="section projects">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-cmd">$ ls -la projects/</span>
        <a href="/projects" class="section-view-all">[view all →]</a>
      </div>
      <div class="projects-grid">
        {projects.map((project, index) => (
          <div class={`reveal stagger-${index + 1}`}>
            <ProjectCard
              title={project.data.title}
              slug={project.slug}
              period={project.data.period}
              role={project.data.role}
              stack={project.data.stack}
              highlights={project.data.highlights}
              metrics={project.data.metrics}
              cover={project.data.cover}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ BLOG ══ -->
  <section class="section blog">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-cmd">$ cat blog/*.md | head</span>
        <a href="/blog" class="section-view-all">[view all →]</a>
      </div>
      <div class="blog-grid">
        {posts.map((post, index) => (
          <div class={`reveal stagger-${index + 1}`}>
            <BlogCard
              title={post.data.title}
              slug={post.slug}
              date={post.data.date}
              summary={post.data.summary}
              category={post.data.category}
              tags={post.data.tags}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Pass Astro data to client script -->
<script define:vars={{ projectsData, postsData, siteEmail: siteConfig.author.email, siteGithub: siteConfig.links.github, siteName: siteConfig.name }}>

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Typewriter ──
  async function typeText(elementId, text, speed = 65) {
    const el = document.getElementById(elementId);
    if (!el) return;
    for (const char of text) {
      el.textContent += char;
      await sleep(speed);
    }
  }

  function show(id) {
    const el = document.getElementById(id);
    if (el) el.hidden = false;
  }

  async function runTypewriter() {
    if (prefersReducedMotion) {
      document.getElementById('t-cmd-1').textContent = 'whoami';
      document.getElementById('t-cmd-2').textContent = 'cat profile.txt';
      document.getElementById('t-cmd-3').textContent = 'ls skills/';
      ['t-out-1','t-out-2','t-out-3','t-line-2','t-line-3','t-line-final','terminal-hint'].forEach(show);
      enableInteractive();
      return;
    }

    await sleep(400);
    await typeText('t-cmd-1', 'whoami', 80);
    await sleep(300);
    show('t-out-1');
    await sleep(600);

    show('t-line-2');
    await typeText('t-cmd-2', 'cat profile.txt', 70);
    await sleep(300);
    show('t-out-2');
    await sleep(700);

    show('t-line-3');
    await typeText('t-cmd-3', 'ls skills/', 80);
    await sleep(300);
    show('t-out-3');
    await sleep(600);

    show('t-line-final');
    await sleep(300);
    show('terminal-hint');
    enableInteractive();
  }

  // ── Interactive Terminal ──
  function enableInteractive() {
    const terminal = document.getElementById('hero-terminal');
    const inputLine = document.getElementById('t-line-final');
    const typedEl = document.getElementById('t-typed');
    if (!terminal || !inputLine || !typedEl) return;

    let buffer = '';

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function appendPromptLine(cmd) {
      const div = document.createElement('div');
      div.className = 't-line t-line-submitted';
      div.innerHTML =
        `<span class="t-prompt"><span class="p-user">${siteName}</span>` +
        `<span class="p-at">@</span><span class="p-host">portfolio</span>` +
        `<span class="p-colon">:</span><span class="p-path">~</span>` +
        `<span class="p-dollar">$ </span></span>` +
        `<span class="t-cmd">${esc(cmd)}</span>`;
      inputLine.before(div);
    }

    function appendOutput(lines) {
      const wrap = document.createElement('div');
      wrap.className = 't-output-block';
      wrap.innerHTML = lines.map(l => {
        let cls = 't-out';
        if (l.bright) cls += ' t-out-bright';
        if (l.accent) cls += ' t-out-accent';
        if (l.error)  cls += ' t-out-error';
        return `<p class="${cls}">${l.html || esc(l.text || '')}</p>`;
      }).join('');
      inputLine.before(wrap);
    }

    function appendSkills(skills) {
      const wrap = document.createElement('div');
      wrap.className = 't-output-block t-skills';
      wrap.innerHTML = skills.map(s => `<span class="t-skill">${esc(s)}</span>`).join('');
      inputLine.before(wrap);
    }

    function scrollToBottom() {
      terminal.scrollTop = terminal.scrollHeight;
    }

    function processCommand(raw) {
      const cmd = raw.trim();
      if (!cmd) return;

      appendPromptLine(cmd);

      const lower = cmd.toLowerCase();
      const parts = lower.split(/\s+/);
      const main = parts[0];
      const arg  = parts.slice(1).join(' ');

      // ── help ──
      if (main === 'help' || main === '?') {
        appendOutput([
          { html: `<span style="color:var(--color-accent)"># available commands</span>` },
          { html: `<span style="color:var(--color-border-hover)">────────────────────────────────────</span>` },
          { html: `  <span style="color:var(--color-prompt-path)">whoami</span>           &nbsp;show identity` },
          { html: `  <span style="color:var(--color-prompt-path)">ls</span>               &nbsp;list files` },
          { html: `  <span style="color:var(--color-prompt-path)">ls skills/</span>       &nbsp;list tech skills` },
          { html: `  <span style="color:var(--color-prompt-path)">ls projects/</span>     &nbsp;list all projects` },
          { html: `  <span style="color:var(--color-prompt-path)">ls blog/</span>         &nbsp;list recent posts` },
          { html: `  <span style="color:var(--color-prompt-path)">cat about.txt</span>    &nbsp;about me` },
          { html: `  <span style="color:var(--color-prompt-path)">cat contact.txt</span>  &nbsp;contact info` },
          { html: `  <span style="color:var(--color-prompt-path)">cd /projects</span>     &nbsp;go to projects page` },
          { html: `  <span style="color:var(--color-prompt-path)">cd /blog</span>         &nbsp;go to blog page` },
          { html: `  <span style="color:var(--color-prompt-path)">clear</span>            &nbsp;clear terminal` },
          { html: `<span style="color:var(--color-border-hover)">────────────────────────────────────</span>` },
        ]);
        return;
      }

      // ── whoami ──
      if (main === 'whoami') {
        appendOutput([
          { text: '풀스택 엔지니어 · AI 프로덕트 빌더', bright: true },
          { text: '백엔드/인프라에 뿌리를 두고, AI 통합부터 프론트엔드까지 혼자 설계합니다.' },
          { text: '복잡한 시스템을 처음부터 끝까지 직접 만들어야 제대로 이해한다고 믿습니다.' },
        ]);
        return;
      }

      // ── ls (root) ──
      if (lower === 'ls' || lower === 'ls -la' || lower === 'ls -l' || lower === 'ls -a') {
        appendOutput([
          { html: `drwxr-xr-x  <span style="color:var(--color-prompt-path)">skills/</span>` },
          { html: `drwxr-xr-x  <span style="color:var(--color-prompt-path)">projects/</span>` },
          { html: `drwxr-xr-x  <span style="color:var(--color-prompt-path)">blog/</span>` },
          { html: `-rw-r--r--  about.txt` },
          { html: `-rw-r--r--  contact.txt` },
          { html: `-rw-r--r--  profile.txt` },
        ]);
        return;
      }

      // ── ls skills/ ──
      if (lower === 'ls skills/' || lower === 'ls skills' || lower === 'skills') {
        appendSkills(['Kotlin','Spring Boot','Java','Python','FastAPI','LangGraph','RAG','Next.js','React','TypeScript','AWS','Kubernetes','Terraform','Docker','PostgreSQL','Redis','Kafka','GitHub Actions','Linux']);
        return;
      }

      // ── ls projects/ ──
      if (lower === 'ls projects/' || lower === 'ls projects' || lower === 'projects') {
        const lines = projectsData.map(p => ({
          html: `  <a href="/projects/${p.slug}" style="color:var(--color-prompt-path);text-decoration:none">${p.slug}/</a>` +
                `<span style="color:var(--color-text-muted)">  ${esc(p.title)}</span>` +
                `<span style="color:var(--color-text-dim)">  [${esc(p.role)}]</span>`
        }));
        appendOutput([
          { html: `total ${projectsData.length}` },
          ...lines,
        ]);
        return;
      }

      // ── ls blog/ ──
      if (lower === 'ls blog/' || lower === 'ls blog' || lower === 'blog' || lower === 'posts') {
        const catColor = { cs: '#5fb3b3', book: '#ffb347', til: '#00ff41' };
        const lines = postsData.map(p => {
          const clr = catColor[p.category] || 'var(--color-accent)';
          const filename = p.slug.split('/').pop() + '.md';
          return {
            html: `  <a href="/blog/${p.slug}" style="color:var(--color-prompt-path);text-decoration:none">${esc(filename)}</a>` +
                  `<span style="color:${clr}">  [${esc(p.category)}]</span>`
          };
        });
        appendOutput([
          { html: `total ${postsData.length}` },
          ...lines,
        ]);
        return;
      }

      // ── cat about.txt ──
      if (lower === 'cat about.txt' || lower === 'about') {
        appendOutput([
          { html: `<span style="color:var(--color-text-muted)"># about.txt</span>` },
          { html: `<span style="color:var(--color-text-bright)">풀스택 엔지니어 · AI 프로덕트 빌더</span>` },
          { text: '백엔드/인프라에 뿌리를 두고, AI 통합부터 프론트엔드까지 혼자 설계합니다.' },
          { text: 'LangGraph AI Agent, Yjs 실시간 협업, K8s+Terraform IaC — 복잡한 시스템을 처음부터 끝까지 직접 만듭니다.' },
        ]);
        return;
      }

      // ── cat contact.txt ──
      if (lower === 'cat contact.txt' || lower === 'contact') {
        appendOutput([
          { html: `<span style="color:var(--color-text-muted)"># contact.txt</span>` },
          { html: `email  :&nbsp;<a href="mailto:${esc(siteEmail)}" style="color:var(--color-accent)">${esc(siteEmail)}</a>` },
          { html: `github :&nbsp;<a href="${esc(siteGithub)}" target="_blank" rel="noopener" style="color:var(--color-accent)">${esc(siteGithub)}</a>` },
        ]);
        return;
      }

      // ── clear ──
      if (lower === 'clear') {
        terminal.querySelectorAll('.t-line:not(#t-line-final), .t-output-block').forEach(el => el.remove());
        return;
      }

      // ── cd ──
      if (main === 'cd') {
        const dest = arg.replace(/^\//, '').split('/')[0];
        if (['projects', 'blog', 'about'].includes(dest)) {
          appendOutput([{ html: `<span style="color:var(--color-accent)">→ navigating to /${dest}...</span>` }]);
          setTimeout(() => { window.location.href = `/${dest}`; }, 700);
        } else if (dest === '' || dest === '~' || dest === '.') {
          appendOutput([{ text: 'already here.' }]);
        } else {
          appendOutput([{ text: `bash: cd: /${dest}: No such file or directory`, error: true }]);
        }
        return;
      }

      // ── pwd ──
      if (lower === 'pwd') {
        appendOutput([{ text: '/home/' + siteName + '/portfolio' }]);
        return;
      }

      // ── echo ──
      if (main === 'echo') {
        appendOutput([{ text: arg }]);
        return;
      }

      // ── Easter eggs ──
      if (lower.includes('rm -rf') || lower.includes('rm -fr')) {
        appendOutput([{ text: 'nice try 😏', bright: true }]);
        return;
      }

      if (main === 'vim' || main === 'vi' || main === 'nano' || main === 'emacs') {
        appendOutput([
          { html: `<span style="color:var(--color-text-muted)"># ${main} — the best editor</span>` },
          { text: '...just kidding, this is a fake terminal.' },
          { html: `type <span style="color:var(--color-accent)">:q!</span> to escape. (doesn't work here)` },
        ]);
        return;
      }

      if (lower === 'git log' || lower === 'git log --oneline') {
        appendOutput([
          { html: `<span style="color:#e6c07b">29a44d9</span> <span style="color:var(--color-accent)">(HEAD → main)</span> Terminal portfolio redesign ✓` },
          { html: `<span style="color:#e6c07b">7811b61</span> Add TIL category and Discord bot post` },
          { html: `<span style="color:#e6c07b">9d73e8b</span> Fix publication date` },
          { html: `<span style="color:#e6c07b">5b4409d</span> Add AWS Lambda + EventBridge post` },
        ]);
        return;
      }

      if (lower === 'git status') {
        appendOutput([
          { html: `On branch <span style="color:var(--color-accent)">main</span>` },
          { text: 'nothing to commit, working tree clean ✓' },
        ]);
        return;
      }

      if (lower.startsWith('npm install') || lower.startsWith('yarn') || lower.startsWith('pnpm install')) {
        const loadingEl = document.createElement('div');
        loadingEl.className = 't-output-block';
        loadingEl.innerHTML = `<p class="t-out">⠋ installing packages...</p>`;
        inputLine.before(loadingEl);
        scrollToBottom();
        const frames = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'];
        let i = 0;
        const iv = setInterval(() => {
          loadingEl.querySelector('p').textContent = `${frames[i++ % frames.length]} installing packages...`;
        }, 80);
        setTimeout(() => {
          clearInterval(iv);
          loadingEl.innerHTML = `<p class="t-out t-out-accent">✓ done in 0.01s — (nothing to install, it's a portfolio)</p>`;
          scrollToBottom();
        }, 1500);
        return;
      }

      if (lower === 'sudo su' || lower === 'sudo bash' || lower.startsWith('sudo ')) {
        appendOutput([{ text: '[sudo] password for ' + siteName + ': ', error: true }]);
        setTimeout(() => {
          appendOutput([{ text: siteName + ' is not in the sudoers file. This incident will be reported.', error: true }]);
          scrollToBottom();
        }, 800);
        return;
      }

      if (lower === 'hello' || lower === 'hi' || lower === 'hey' || lower === '안녕') {
        appendOutput([{ text: 'Hello! 👋  type help to see what you can do here.', bright: true }]);
        return;
      }

      if (lower === 'exit' || lower === 'logout') {
        appendOutput([{ text: 'logout — session ended. (reload to restart)' }]);
        document.removeEventListener('keydown', handleKey);
        return;
      }

      if (lower === 'cat profile.txt') {
        appendOutput([
          { text: '풀스택 엔지니어 · AI 프로덕트 빌더', bright: true },
          { text: '백엔드/인프라에 뿌리를 두고, AI 통합부터 프론트엔드까지 혼자 설계합니다.' },
          { text: '복잡한 시스템을 처음부터 끝까지 직접 만들어야 제대로 이해한다고 믿습니다.' },
        ]);
        return;
      }

      if (lower === 'uname -a' || lower === 'uname') {
        appendOutput([{ text: 'Portfolio 2026 projectmiluju-pc 6.x.x SMP x86_64 GNU/Linux' }]);
        return;
      }

      if (lower === 'uptime') {
        appendOutput([{ text: 'up forever, load average: 0.00, 0.00, 0.00' }]);
        return;
      }

      if (lower === 'date') {
        appendOutput([{ text: new Date().toString() }]);
        return;
      }

      // ── Unknown command ──
      appendOutput([{
        html: `bash: <span style="color:var(--color-text-bright)">${esc(parts[0])}</span>: command not found — type <span style="color:var(--color-accent)">help</span> for available commands`,
        error: true,
      }]);
    }

    // ── Keyboard handler ──
    function handleKey(e) {
      // Ignore when user is typing in an actual input/textarea
      const tag = document.activeElement?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;

      if (e.ctrlKey && e.key === 'c') {
        appendPromptLine(buffer + '^C');
        buffer = '';
        typedEl.textContent = '';
        scrollToBottom();
        return;
      }

      if (e.ctrlKey && e.key === 'l') {
        terminal.querySelectorAll('.t-line:not(#t-line-final), .t-output-block').forEach(el => el.remove());
        buffer = '';
        typedEl.textContent = '';
        return;
      }

      if (e.ctrlKey || e.altKey || e.metaKey) return;

      if (e.key === 'Enter') {
        e.preventDefault();
        const cmd = buffer;
        buffer = '';
        typedEl.textContent = '';
        processCommand(cmd);
        scrollToBottom();
        return;
      }

      if (e.key === 'Backspace') {
        buffer = buffer.slice(0, -1);
        typedEl.textContent = buffer;
        return;
      }

      if (e.key.length === 1) {
        e.preventDefault();
        buffer += e.key;
        typedEl.textContent = buffer;
        scrollToBottom();
        return;
      }
    }

    document.addEventListener('keydown', handleKey);

    // Hide hint bar after first input
    let hintHidden = false;
    document.addEventListener('keydown', () => {
      if (!hintHidden) {
        hintHidden = true;
        document.getElementById('terminal-hint')?.remove();
      }
    }, { once: true });
  }

  runTypewriter();
</script>

