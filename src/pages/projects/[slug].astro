---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content, headings } = await project.render();

const { title, period, role, stack, links, highlights, metrics, cover, youtube } = project.data;
---

<BaseLayout
  title={title}
  description={`${role} | ${highlights?.[0] || ''}`}
  ogImage={cover}
  ogType="article"
>
  <article class="project-detail">
    <div class="container">

      <!-- Back -->
      <a href="/projects" class="back-link">
        <span class="back-arrow">←</span> cd /projects
      </a>

      <!-- Project Header Terminal -->
      <div class="project-header-terminal">
        <div class="terminal-titlebar">
          <div class="dots">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
          </div>
          <span class="titlebar-cmd">$ cat {project.slug}/README.md</span>
        </div>

        <div class="terminal-header-body">
          <!-- Fields -->
          <div class="field-grid">
            <div class="field-row">
              <span class="fkey">project</span>
              <span class="fsep"> : </span>
              <span class="fval fval-title">{title}</span>
            </div>
            <div class="field-row">
              <span class="fkey">period </span>
              <span class="fsep"> : </span>
              <span class="fval">{period}</span>
            </div>
            <div class="field-row">
              <span class="fkey">role   </span>
              <span class="fsep"> : </span>
              <span class="fval fval-role">{role}</span>
            </div>
            <div class="field-row">
              <span class="fkey">stack  </span>
              <span class="fsep"> : </span>
              <div class="fval-stack">
                {stack.map((tech) => (
                  <span class="stag">{tech}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- Links -->
          {links && (links.github || links.demo) && (
            <div class="project-links">
              {links.github && (
                <a href={links.github} target="_blank" rel="noopener noreferrer" class="plink">
                  [github →]
                </a>
              )}
              {links.demo && (
                <a href={links.demo} target="_blank" rel="noopener noreferrer" class="plink">
                  [demo →]
                </a>
              )}
            </div>
          )}

          <!-- Metrics -->
          {metrics && metrics.length > 0 && (
            <div class="metrics-block">
              <div class="metrics-header">
                <span class="metrics-label">// key metrics</span>
              </div>
              <ul class="metrics-list">
                {metrics.map((metric) => (
                  <li class="metric-item">
                    <span class="metric-arrow">↗</span> {metric}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      <!-- YouTube -->
      {youtube && (
        <div class="video-section">
          <div class="video-header">
            <span class="prompt-dollar">$</span>
            <span class="video-cmd">open demo.mp4</span>
          </div>
          <YouTubeEmbed videoId={youtube} title={`${title} 데모 영상`} />
        </div>
      )}

      <!-- Content Layout -->
      <div class="project-layout">
        <aside class="project-sidebar">
          <TableOfContents headings={headings} />
        </aside>

        <div class="project-content prose">
          <Content />
        </div>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding: var(--space-8) 0 var(--space-20);
    font-family: var(--font-mono);
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-accent); }
  .back-arrow { color: var(--color-accent); }

  /* Header Terminal */
  .project-header-terminal {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-8);
    max-width: var(--content-width);
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .dots { display: flex; gap: 6px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background-color: #ff5f57; }
  .dot-y { background-color: #febc2e; }
  .dot-g { background-color: #28c840; }

  .titlebar-cmd {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .terminal-header-body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Field Grid */
  .field-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-row {
    display: flex;
    align-items: flex-start;
    font-size: var(--text-sm);
  }

  .fkey {
    color: var(--color-text-dim);
    white-space: pre;
    flex-shrink: 0;
  }

  .fsep { color: var(--color-text-dim); flex-shrink: 0; }

  .fval { color: var(--color-text-muted); }
  .fval-title {
    color: var(--color-text-bright);
    font-size: var(--text-lg);
    font-weight: 700;
  }
  .fval-role { color: var(--color-accent); }

  .fval-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .stag {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px var(--space-2);
  }

  /* Links */
  .project-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .plink {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    transition: all var(--transition-fast);
  }

  .plink:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Metrics */
  .metrics-block {
    border: 1px solid rgba(0, 255, 65, 0.2);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .metrics-header {
    padding: var(--space-2) var(--space-4);
    background-color: rgba(0, 255, 65, 0.05);
    border-bottom: 1px solid rgba(0, 255, 65, 0.15);
  }

  .metrics-label {
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .metrics-list {
    list-style: none;
    padding: var(--space-3) var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .metric-item {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .metric-arrow {
    color: var(--color-accent);
    margin-right: var(--space-1);
  }

  /* Video */
  .video-section {
    margin-bottom: var(--space-8);
    max-width: var(--content-width);
  }

  .video-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .prompt-dollar { color: var(--color-accent); }
  .video-cmd { color: var(--color-text-muted); }

  /* Layout */
  .project-layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width, 240px);
    gap: var(--space-10);
    align-items: start;
  }

  .project-sidebar { order: 2; }
  .project-content { order: 1; max-width: var(--content-width); }

  /* Prose */
  .prose {
    font-family: var(--font-mono);
    color: var(--color-text);
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-bright);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h2)::before { content: '## '; color: var(--color-accent); }

  .prose :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-bright);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(h3)::before { content: '### '; color: var(--color-accent); }

  .prose :global(h4) {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-bright);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .prose :global(h4)::before { content: '#### '; color: var(--color-accent); }

  .prose :global(p) {
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
    line-height: 1.7;
  }

  .prose :global(ul li)::marker { color: var(--color-accent); }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 255, 65, 0.3);
    transition: border-color var(--transition-fast);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-bg-elevated);
    color: var(--color-accent);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .prose :global(pre) {
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin: var(--space-6) 0;
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    color: var(--color-text-muted);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: var(--space-6) 0;
    max-width: 100%;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin: var(--space-6) 0;
  }

  .prose :global(th) {
    background-color: var(--color-bg-elevated);
    color: var(--color-accent);
    padding: var(--space-2) var(--space-3);
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .prose :global(tr:nth-child(even) td) {
    background-color: var(--color-bg-alt);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .project-layout {
      grid-template-columns: 1fr;
    }

    .project-sidebar { display: none; }
    .project-content { max-width: none; order: 1; }
  }

  @media (max-width: 768px) {
    .fval-title { font-size: var(--text-base); }
    .field-row { font-size: var(--text-xs); }
  }
</style>
