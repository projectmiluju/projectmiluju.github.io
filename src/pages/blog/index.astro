---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

const categoryLabels: Record<string, string> = {
  cs: 'CS Notes',
  book: 'Book',
  til: 'TIL',
};

const catColor: Record<string, string> = {
  cs: '#5fb3b3',
  book: '#ffb347',
  til: '#00ff41',
};

const postsBySeries = allPosts.reduce((acc, post) => {
  const series = post.data.series || '기타';
  if (!acc[series]) acc[series] = [];
  acc[series].push(post);
  return acc;
}, {} as Record<string, typeof allPosts>);
---

<BaseLayout
  title="Blog"
  description="CS 개념 정리, 개발 서적 리뷰, TIL 경험을 기록합니다."
>
  <div class="blog-page">
    <div class="container">

      <!-- ══ Header ══ -->
      <header class="page-header reveal">
        <div class="header-cmd">
          <span class="p-dollar">$ </span>
          <span class="p-cmd">ls -la blog/</span>
          <span class="p-result"> # {allPosts.length} posts found</span>
        </div>
        <p class="header-desc">CS 개념 정리, 개발 서적 리뷰, TIL 경험을 기록합니다.</p>
      </header>

      <!-- ══ Search ══ -->
      <div class="search-section reveal">
        <div class="search-row">
          <span class="search-prefix">$ grep -r &quot;</span>
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder="keyword"
            autocomplete="off"
            spellcheck="false"
          />
          <span class="search-suffix">&quot; blog/</span>
          <button type="button" id="search-btn" class="search-btn" aria-label="검색">
            [enter]
          </button>
        </div>
      </div>

      <!-- ══ Filters ══ -->
      <div class="filters-section reveal">
        <div class="filter-row">
          <span class="filter-prefix"># category:</span>
          <div class="filter-pills" id="category-filter">
            <button class="pill active" data-category="">all</button>
            {siteConfig.blogCategories.map(cat => (
              <button class="pill" data-category={cat.slug}>[{cat.slug}]&nbsp;{cat.name}</button>
            ))}
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-prefix"># series: </span>
          <div class="series-grid" id="series-filter">
            {siteConfig.blogSeries.map(s => (
              <button
                class="series-pill"
                data-series={s.slug}
                data-category={s.category}
              >
                <span class="series-icon">{s.icon}</span>
                <span class="series-name">{s.name}</span>
                <span class="series-count">{postsBySeries[s.slug]?.length || 0}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="filter-row filter-row-tags">
          <span class="filter-prefix"># tags:&nbsp;&nbsp;&nbsp;</span>
          <div class="tag-pills" id="tag-filter">
            {allTags.map(tag => (
              <button class="tag-pill" data-tag={tag}>#{tag}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- Active filters bar -->
      <div class="active-filters" id="active-filters" hidden>
        <span class="af-prefix">$ filter:</span>
        <div id="filter-badges" class="filter-badges"></div>
        <button class="af-clear" id="clear-filters">[clear]</button>
      </div>

      <!-- ══ Posts ══ -->
      <div id="posts-container" class="series-sections">
        {siteConfig.blogSeries.map(seriesConfig => {
          const seriesPosts = postsBySeries[seriesConfig.slug] || [];
          if (seriesPosts.length === 0) return null;
          return (
            <section class="series-block reveal" data-category={seriesConfig.category} data-series-name={seriesConfig.slug}>
              <div class="series-header">
                <span class="series-header-icon">{seriesConfig.icon}</span>
                <span class="series-header-name">{seriesConfig.name}</span>
                <span class="series-header-count">{seriesPosts.length} posts</span>
                <button class="series-view-all" data-series={seriesConfig.slug}>[view all]</button>
              </div>
              <div class="series-grid-layout">
                {seriesPosts.map(post => {
                  const dateStr = post.data.date.toISOString().split('T')[0];
                  const clr = catColor[post.data.category] || 'var(--color-accent)';
                  return (
                    <article 
                      class="post-card-wrapper" 
                      data-title={post.data.title}
                      data-summary={post.data.summary}
                      data-category={post.data.category}
                      data-series={post.data.series || '기타'}
                      data-tags={post.data.tags.join(',')}
                    >
                      <div class="blog-post-card">
                        <a href={`/blog/${post.slug}`} class="card-link">
                          <div class="card-header">
                            <span class="header-icon">▶</span>
                            <span class="header-file">{(post.data.series || '기타')}/</span>
                            <span class="header-date">{dateStr}</span>
                          </div>
                          
                          {post.data.cover && (
                            <div class="card-cover">
                              <img src={post.data.cover} alt={post.data.title} loading="lazy" />
                              <div class="card-cover-overlay"></div>
                            </div>
                          )}

                          <div class="card-body">
                            <h3 class="card-title">{post.data.title}</h3>
                            <div class="card-field">
                              <span class="field-name">category</span>
                              <span class="field-sep"> : </span>
                              <span class="field-value" style={{ color: clr }}>[{categoryLabels[post.data.category]}]</span>
                            </div>
                            <p class="card-summary">{post.data.summary}</p>
                            <div class="card-stack">
                              {post.data.tags.slice(0, 3).map(tag => (
                                <span class="stack-tag">#{tag}</span>
                              ))}
                            </div>
                          </div>
                          
                          <div class="card-footer">
                            <span class="footer-enter">↵ enter</span>
                          </div>
                        </a>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          );
        })}

        {postsBySeries['기타'] && postsBySeries['기타'].length > 0 && (
          <section class="series-block reveal" data-series-name="기타">
            <div class="series-header">
              <span class="series-header-icon">📄</span>
              <span class="series-header-name">기타</span>
              <span class="series-header-count">{postsBySeries['기타'].length} posts</span>
            </div>
            <div class="series-grid-layout">
              {postsBySeries['기타'].map(post => {
                const dateStr = post.data.date.toISOString().split('T')[0];
                const clr = catColor[post.data.category] || 'var(--color-accent)';
                return (
                  <article 
                    class="post-card-wrapper"
                    data-title={post.data.title}
                    data-summary={post.data.summary}
                    data-category={post.data.category}
                    data-series="기타"
                    data-tags={post.data.tags.join(',')}
                  >
                    <div class="blog-post-card">
                      <a href={`/blog/${post.slug}`} class="card-link">
                        <div class="card-header">
                          <span class="header-icon">▶</span>
                          <span class="header-file">기타/</span>
                          <span class="header-date">{dateStr}</span>
                        </div>
                        
                        {post.data.cover && (
                          <div class="card-cover">
                            <img src={post.data.cover} alt={post.data.title} loading="lazy" />
                            <div class="card-cover-overlay"></div>
                          </div>
                        )}

                        <div class="card-body">
                          <h3 class="card-title">{post.data.title}</h3>
                          <div class="card-field">
                            <span class="field-name">category</span>
                            <span class="field-sep"> : </span>
                            <span class="field-value" style={{ color: clr }}>[{categoryLabels[post.data.category]}]</span>
                          </div>
                          <p class="card-summary">{post.data.summary}</p>
                          <div class="card-stack">
                            {post.data.tags.slice(0, 3).map(tag => (
                              <span class="stack-tag">#{tag}</span>
                            ))}
                          </div>
                        </div>
                        
                        <div class="card-footer">
                          <span class="footer-enter">↵ enter</span>
                        </div>
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        )}

        <!-- Empty state -->
        <div class="empty-state" id="empty-state" hidden>
          <span class="p-dollar">$ </span>
          <span class="empty-cmd">grep -r "</span><span id="empty-query" class="empty-query"></span><span class="empty-cmd">" blog/</span>
          <p class="empty-msg">No results found. <button id="reset-filters" class="reset-btn">[clear filters]</button></p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let filters = { category: '', series: '', tag: '', search: '' };

    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchBtn   = document.getElementById('search-btn');
    const catFilter   = document.getElementById('category-filter');
    const serFilter   = document.getElementById('series-filter');
    const tagFilter   = document.getElementById('tag-filter');
    const activeBar   = document.getElementById('active-filters');
    const badgesEl    = document.getElementById('filter-badges');
    const clearBtn    = document.getElementById('clear-filters');
    const resetBtn    = document.getElementById('reset-filters');
    const postsContainer = document.getElementById('posts-container');
    const emptyState  = document.getElementById('empty-state');
    const emptyQuery  = document.getElementById('empty-query');

    // URL params
    const p = new URLSearchParams(location.search);
    if (p.get('category')) filters.category = p.get('category')!;
    if (p.get('series'))   filters.series   = p.get('series')!;
    if (p.get('tag'))      filters.tag      = p.get('tag')!;
    if (p.get('q'))      { filters.search   = p.get('q')!; if (searchInput) searchInput.value = filters.search; }
    applyFilters();

    searchBtn?.addEventListener('click', () => { filters.search = searchInput.value.trim(); applyFilters(); });
    searchInput?.addEventListener('keypress', e => { if (e.key === 'Enter') { filters.search = searchInput.value.trim(); applyFilters(); } });

    catFilter?.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest('.pill') as HTMLElement;
      if (btn) { filters.category = btn.dataset.category || ''; filters.series = ''; applyFilters(); }
    });

    serFilter?.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest('.series-pill') as HTMLElement;
      if (btn) { filters.series = btn.dataset.series || ''; if (btn.dataset.category) filters.category = btn.dataset.category; applyFilters(); }
    });

    document.querySelectorAll('.series-view-all').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const b = btn as HTMLElement;
        filters.series = b.dataset.series || '';
        const block = b.closest('.series-block') as HTMLElement;
        if (block?.dataset.category) filters.category = block.dataset.category;
        applyFilters();
      });
    });

    tagFilter?.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest('.tag-pill') as HTMLElement;
      if (btn) { filters.tag = filters.tag === btn.dataset.tag ? '' : btn.dataset.tag || ''; applyFilters(); }
    });

    clearBtn?.addEventListener('click', clearAll);
    resetBtn?.addEventListener('click', clearAll);
    function clearAll() { filters = { category: '', series: '', tag: '', search: '' }; if (searchInput) searchInput.value = ''; applyFilters(); }

    function applyFilters() {
      const params = new URLSearchParams();
      if (filters.category) params.set('category', filters.category);
      if (filters.series)   params.set('series',   filters.series);
      if (filters.tag)      params.set('tag',      filters.tag);
      if (filters.search)   params.set('q',        filters.search);
      history.replaceState({}, '', params.toString() ? `/blog?${params}` : '/blog');

      let totalVisible = 0;
      const q = filters.search.toLowerCase();
      // Limit to 3 per series if in "all" state OR "category-only" state
      const isLimitedState = !filters.series && !filters.tag && !filters.search;

      // Track card visibility per series for the limited state
      const seriesVisibleCounts: Record<string, number> = {};

      // Filter individual cards
      document.querySelectorAll('.post-card-wrapper').forEach(el => {
        const card = el as HTMLElement;
        const cCat = card.dataset.category;
        const cSer = card.dataset.series || '기타';
        const cTags = card.dataset.tags?.split(',') || [];
        const cTitle = card.dataset.title?.toLowerCase() || '';
        const cSum = card.dataset.summary?.toLowerCase() || '';

        let isMatch = true;
        if (filters.category && cCat !== filters.category) isMatch = false;
        if (filters.series && cSer !== filters.series) isMatch = false;
        if (filters.tag && !cTags.includes(filters.tag)) isMatch = false;
        if (q && !cTitle.includes(q) && !cSum.includes(q) && !cTags.some(t => t.toLowerCase().includes(q))) isMatch = false;

        let shouldShow = isMatch;
        // If in a limited state, apply the 3-card-per-series limit
        if (isLimitedState && isMatch) {
          if (!seriesVisibleCounts[cSer]) seriesVisibleCounts[cSer] = 0;
          if (seriesVisibleCounts[cSer] >= 3) {
            shouldShow = false;
          }
          seriesVisibleCounts[cSer]++;
        }

        card.style.display = shouldShow ? '' : 'none';
        if (shouldShow) totalVisible++;
      });

      // Filter series blocks
      document.querySelectorAll('.series-block').forEach(el => {
        const block = el as HTMLElement;
        const visibleInBlock = block.querySelectorAll('.post-card-wrapper:not([style*="display: none"])').length;
        block.style.display = visibleInBlock > 0 ? '' : 'none';
      });

      emptyState!.hidden = totalVisible > 0;
      if (emptyQuery) emptyQuery.textContent = filters.search || filters.tag || filters.series || filters.category;

      updateUI();
      renderBadges();
    }

    function updateUI() {
      catFilter?.querySelectorAll('.pill').forEach(b => (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.category === filters.category));
      serFilter?.querySelectorAll('.series-pill').forEach(b => {
        const sb = b as HTMLElement;
        const isVisible = !filters.category || sb.dataset.category === filters.category;
        sb.style.display = isVisible ? '' : 'none';
        sb.classList.toggle('active', sb.dataset.series === filters.series);
      });

      // Update Tag pills visibility
      const visibleCards = Array.from(document.querySelectorAll('.post-card-wrapper')).filter(el => {
        const card = el as HTMLElement;
        if (filters.category && card.dataset.category !== filters.category) return false;
        if (filters.series && card.dataset.series !== filters.series) return false;
        return true;
      }) as HTMLElement[];
      
      const relevantTags = new Set(visibleCards.flatMap(c => c.dataset.tags?.split(',') || []));
      tagFilter?.querySelectorAll('.tag-pill').forEach(b => {
        const tb = b as HTMLElement;
        const isVisible = relevantTags.has(tb.dataset.tag || '');
        tb.style.display = isVisible ? '' : 'none';
        tb.classList.toggle('active', tb.dataset.tag === filters.tag);
      });
    }

    function renderBadges() {
      if (!badgesEl) return;
      const parts = [];
      if (filters.category) parts.push(`category=${filters.category}`);
      if (filters.series)   parts.push(`series="${filters.series}"`);
      if (filters.tag)      parts.push(`tag=#${filters.tag}`);
      if (filters.search)   parts.push(`q="${filters.search}"`);
      badgesEl.innerHTML = parts.map(p => `<span class="badge">${p}</span>`).join('');
      activeBar!.hidden = parts.length === 0;
    }
  });
</script>

<style>
  .blog-page {
    padding: calc(var(--header-height) + var(--space-10)) 0 var(--space-20);
    font-family: var(--font-mono);
  }

  .page-header { margin-bottom: var(--space-8); }
  .header-cmd { font-size: var(--text-base); margin-bottom: var(--space-3); }
  .p-dollar { color: var(--color-accent); }
  .p-cmd    { color: var(--color-text-bright); }
  .p-result { color: var(--color-text-muted); font-size: var(--text-sm); }
  .header-desc { font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; padding-left: var(--space-4); border-left: 2px solid var(--color-border); }

  .search-section { margin-bottom: var(--space-6); }
  .search-row { display: flex; align-items: center; gap: 0; font-size: var(--text-sm); max-width: 560px; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; background-color: var(--color-bg-alt); transition: border-color var(--transition-fast); }
  .search-row:focus-within { border-color: var(--color-accent); }
  .search-prefix, .search-suffix { color: var(--color-text-muted); padding: var(--space-2) var(--space-2) var(--space-2) var(--space-3); white-space: nowrap; flex-shrink: 0; }
  .search-input { flex: 1; background: transparent; border: none; outline: none; color: var(--color-text-bright); font-family: var(--font-mono); font-size: var(--text-sm); padding: var(--space-2) 0; min-width: 0; }
  .search-input::placeholder { color: var(--color-text-dim); }
  .search-btn { font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-2) var(--space-3); background: transparent; border: none; border-left: 1px solid var(--color-border); color: var(--color-text-muted); cursor: pointer; white-space: nowrap; transition: all var(--transition-fast); }
  .search-btn:hover { color: var(--color-accent); background-color: var(--color-accent-light); }

  .filters-section { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-6); padding: var(--space-4); background-color: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .filter-row { display: flex; align-items: flex-start; gap: var(--space-3); }
  .filter-row-tags { align-items: center; flex-wrap: wrap; }
  .filter-prefix { font-size: var(--text-xs); color: var(--color-text-muted); white-space: nowrap; padding-top: 3px; flex-shrink: 0; }
  .filter-pills { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .pill { font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-1) var(--space-3); background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-sm); color: var(--color-text-muted); cursor: pointer; transition: all var(--transition-fast); }
  .pill:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .pill.active { border-color: var(--color-accent); color: var(--color-accent); background-color: var(--color-accent-light); }

  .series-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .series-pill { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-1) var(--space-2); background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-sm); color: var(--color-text-muted); cursor: pointer; transition: all var(--transition-fast); }
  .series-pill:hover { border-color: var(--color-accent); color: var(--color-text-bright); }
  .series-pill.active { border-color: var(--color-accent); color: var(--color-accent); background-color: var(--color-accent-light); }
  .series-icon { font-size: 1em; }
  .series-count { font-size: var(--text-xs); color: var(--color-text-dim); margin-left: 2px; }

  .tag-pills { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .tag-pill { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-text-muted); background: transparent; border: none; cursor: pointer; padding: var(--space-1) var(--space-1); transition: color var(--transition-fast); }
  .tag-pill:hover { color: var(--color-accent); }
  .tag-pill.active { color: var(--color-accent); text-decoration: underline; }

  .active-filters { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); font-size: var(--text-xs); padding: var(--space-2) var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg-alt); flex-wrap: wrap; }
  .af-prefix { color: var(--color-accent); flex-shrink: 0; }
  .filter-badges { display: flex; gap: var(--space-2); flex-wrap: wrap; flex: 1; }
  .badge { color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 0.1em 0.4em; border-radius: var(--radius-sm); }
  .af-clear { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-error); background: none; border: none; cursor: pointer; margin-left: auto; flex-shrink: 0; }
  .af-clear:hover { opacity: 0.8; }

  .series-sections { display: flex; flex-direction: column; gap: var(--space-10); }
  .series-header { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-4); padding-bottom: var(--space-2); border-bottom: 1px solid var(--color-border); }
  .series-header-icon { font-size: var(--text-base); }
  .series-header-name { color: var(--color-text-bright); font-size: var(--text-base); font-weight: 600; flex: 1; }
  .series-header-count { color: var(--color-text-muted); font-size: var(--text-xs); }
  .series-view-all { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-accent); background: none; border: 1px solid var(--color-accent); padding: var(--space-1) var(--space-2); border-radius: var(--radius-sm); cursor: pointer; transition: all var(--transition-fast); }
  .series-view-all:hover { background-color: var(--color-accent-light); }
  .series-grid-layout { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-6); }

  /* Blog Post Card (ProjectCard Style) */
  .blog-post-card { background-color: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: border-color var(--transition-fast), box-shadow var(--transition-fast); display: flex; flex-direction: column; height: 100%; }
  .blog-post-card:hover { border-color: var(--color-accent); box-shadow: var(--shadow-card-hover); }
  .card-link { display: flex; flex-direction: column; height: 100%; text-decoration: none; color: inherit; }
  .card-header { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); background-color: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border); overflow: hidden; }
  .header-icon { color: var(--color-accent); font-size: var(--text-xs); flex-shrink: 0; transition: transform var(--transition-fast); }
  .blog-post-card:hover .header-icon { transform: translateX(3px); }
  .header-file { color: var(--color-text-bright); font-size: var(--text-xs); font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .header-date { font-size: var(--text-xs); color: var(--color-text-muted); flex-shrink: 0; }
  .card-cover { position: relative; aspect-ratio: 16 / 9; overflow: hidden; background-color: var(--color-code-bg); }
  .card-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow), filter var(--transition-slow); filter: grayscale(30%) brightness(0.8); }
