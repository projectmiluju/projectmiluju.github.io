---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const { title, date, summary, tags, category, series } = post.data;

const categoryMap: Record<string, { label: string; color: string }> = {
  cs:   { label: 'CS Notes', color: '#5fb3b3' },
  book: { label: 'Book',     color: '#ffb347' },
  til:  { label: 'TIL',      color: '#00ff41' },
};
const cat = categoryMap[category] || { label: category, color: 'var(--color-accent)' };

const formattedDate = date.toISOString().split('T')[0];

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .filter((p) =>
    p.data.category === category ||
    p.data.tags.some((t) => tags.includes(t))
  )
  .slice(0, 3);
---

<BaseLayout title={title} description={summary} ogType="article">
  <article class="blog-post">
    <div class="container">

      <!-- Back -->
      <a href="/blog" class="back-link">
        <span class="back-arrow">←</span> cd /blog
      </a>

      <!-- Post Header Terminal Window -->
      <div class="post-header-terminal">
        <div class="terminal-titlebar">
          <div class="dots">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
          </div>
          <span class="titlebar-cmd">$ cat {category}/{post.slug.split('/').pop()}.md</span>
        </div>
        <div class="terminal-header-body">
          <div class="post-meta-row">
            <span class="cat-badge" style={`color: ${cat.color}; border-color: ${cat.color}33`}>[{cat.label}]</span>
            <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
            {series && <span class="post-series">series: {series}</span>}
          </div>

          <h1 class="post-title"><span class="title-hash"># </span>{title}</h1>

          <p class="post-summary"><span class="summary-gt">&gt; </span>{summary}</p>

          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => (
                <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="ptag">#{tag}</a>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Content Layout -->
      <div class="post-layout">
        <aside class="post-sidebar">
          <TableOfContents headings={headings} />
        </aside>

        <div class="post-content-wrap">
          <div class="post-content prose">
            <Content />
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="post-nav" aria-label="이전/다음 글">
        <div class="nav-item nav-prev">
          {prevPost && (
            <a href={`/blog/${prevPost.slug}`} class="nav-link">
              <span class="nav-label">← prev</span>
              <span class="nav-title">{prevPost.data.title}</span>
            </a>
          )}
        </div>
        <div class="nav-item nav-next">
          {nextPost && (
            <a href={`/blog/${nextPost.slug}`} class="nav-link nav-link-right">
              <span class="nav-label">next →</span>
              <span class="nav-title">{nextPost.data.title}</span>
            </a>
          )}
        </div>
      </nav>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section class="related-section">
          <div class="related-header">
            <span class="prompt-dollar">$</span>
            <span class="related-cmd">ls related/ # {relatedPosts.length} files</span>
          </div>
          <ul class="related-list">
            {relatedPosts.map((p) => {
              const rcat = categoryMap[p.data.category] || { label: p.data.category, color: 'var(--color-accent)' };
              return (
                <li class="related-item">
                  <a href={`/blog/${p.slug}`} class="related-link">
                    <span class="related-arrow">▶</span>
                    <span class="related-title">{p.data.title}</span>
                    <span class="related-cat" style={`color: ${rcat.color}`}>[{rcat.label}]</span>
                    <span class="related-date">{p.data.date.toISOString().split('T')[0]}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: var(--space-8) 0 var(--space-20);
    font-family: var(--font-mono);
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-accent); }
  .back-arrow { color: var(--color-accent); }

  /* Post Header Terminal */
  .post-header-terminal {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-10);
    max-width: var(--content-width);
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .dots { display: flex; gap: 6px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background-color: #ff5f57; }
  .dot-y { background-color: #febc2e; }
  .dot-g { background-color: #28c840; }

  .titlebar-cmd {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .terminal-header-body {
    padding: var(--space-6) var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .cat-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    border: 1px solid;
    border-radius: var(--radius-sm);
    padding: 2px var(--space-2);
    letter-spacing: 0.02em;
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .post-series {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .post-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-bright);
    line-height: 1.25;
    margin: 0;
  }

  .title-hash { color: var(--color-accent); }

  .post-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }

  .summary-gt { color: var(--color-text-dim); }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .ptag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .ptag:hover { color: var(--color-accent); }

  /* Layout */
  .post-layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width, 240px);
    gap: var(--space-10);
    align-items: start;
  }

  .post-sidebar { order: 2; }
  .post-content-wrap { order: 1; }

  /* Prose */
  .prose {
    font-family: var(--font-mono);
    color: var(--color-text);
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-bright);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h2)::before { content: '## '; color: var(--color-accent); }

  .prose :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-bright);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(h3)::before { content: '### '; color: var(--color-accent); }

  .prose :global(h4) {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-bright);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .prose :global(h4)::before { content: '#### '; color: var(--color-accent); }

  .prose :global(p) {
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
    line-height: 1.7;
  }

  .prose :global(ul li)::marker { color: var(--color-accent); }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 255, 65, 0.3);
    transition: border-color var(--transition-fast);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-bg-elevated);
    color: var(--color-accent);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .prose :global(pre) {
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin: var(--space-6) 0;
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    color: var(--color-text-muted);
    font-style: normal;
  }

  .prose :global(blockquote)::before {
    content: '> ';
    color: var(--color-accent);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: var(--space-6) 0;
    max-width: 100%;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin: var(--space-6) 0;
  }

  .prose :global(th) {
    background-color: var(--color-bg-elevated);
    color: var(--color-accent);
    padding: var(--space-2) var(--space-3);
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .prose :global(tr:nth-child(even) td) {
    background-color: var(--color-bg-alt);
  }

  /* Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-16);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    max-width: var(--content-width);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    border-color: var(--color-accent);
    background-color: rgba(0, 255, 65, 0.04);
  }

  .nav-link-right { text-align: right; }

  .nav-label {
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .nav-title {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Related Posts */
  .related-section {
    margin-top: var(--space-12);
    max-width: var(--content-width);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .related-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-xs);
  }

  .prompt-dollar { color: var(--color-accent); }
  .related-cmd { color: var(--color-text-muted); }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-item {
    border-bottom: 1px solid var(--color-border);
  }

  .related-item:last-child { border-bottom: none; }

  .related-link {
    display: grid;
    grid-template-columns: 16px 1fr auto auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--transition-fast);
  }

  .related-link:hover {
    background-color: rgba(0, 255, 65, 0.04);
  }

  .related-arrow {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    transition: color var(--transition-fast);
  }

  .related-link:hover .related-arrow { color: var(--color-accent); }

  .related-title {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .related-link:hover .related-title { color: var(--color-text-bright); }

  .related-cat {
    font-size: var(--text-xs);
    white-space: nowrap;
  }

  .related-date {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    white-space: nowrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-sidebar { display: none; }
    .post-content-wrap { order: 1; }
  }

  @media (max-width: 768px) {
    .post-title { font-size: var(--text-2xl); }

    .post-nav {
      grid-template-columns: 1fr;
    }

    .nav-link-right { text-align: left; }

    .related-link {
      grid-template-columns: 16px 1fr auto;
    }

    .related-date { display: none; }
  }
</style>
