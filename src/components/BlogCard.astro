---
interface Props {
  title: string;
  slug: string;
  date: Date;
  summary: string;
  category: string;
  tags?: string[];
}

const { title, slug, date, summary, category, tags = [] } = Astro.props;

const categoryMap: Record<string, { label: string; prefix: string }> = {
  cs: { label: 'CS Notes', prefix: 'cs' },
  book: { label: 'Book', prefix: 'book' },
  til: { label: 'TIL', prefix: 'til' },
};

const cat = categoryMap[category] || { label: category, prefix: category };

const formattedDate = date.toISOString().split('T')[0]; // YYYY-MM-DD
---

<article class="blog-card" data-category={category}>
  <a href={`/blog/${slug}`} class="card-link">

    <!-- cat command line -->
    <div class="card-cmd">
      <span class="cmd-dollar">$</span>
      <span class="cmd-text"> cat <span class="cmd-path">{cat.prefix}/{slug.split('/').pop()}.md</span></span>
    </div>

    <!-- File content -->
    <div class="card-content">
      <div class="content-meta">
        <span class="meta-category">[{cat.label}]</span>
        <span class="meta-date">{formattedDate}</span>
      </div>

      <h3 class="card-title"># {title}</h3>

      <p class="card-summary">
        <span class="summary-prefix">&gt; </span>{summary}
      </p>

      {tags.length > 0 && (
        <div class="card-tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Read link -->
    <div class="card-read">
      <span class="read-link">[→ open]</span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    overflow: hidden;
  }

  .blog-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Command line header */
  .card-cmd {
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    overflow: hidden;
    white-space: nowrap;
  }

  .cmd-dollar {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .cmd-text {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cmd-path {
    color: var(--color-prompt-path);
  }

  /* Content */
  .card-content {
    flex: 1;
    padding: var(--space-4) var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .content-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .meta-category {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  /* Category color variants */
  .blog-card[data-category="cs"] .meta-category {
    color: #5fb3b3;
  }

  .blog-card[data-category="book"] .meta-category {
    color: #ffb347;
  }

  .blog-card[data-category="til"] .meta-category {
    color: #00ff41;
  }

  .meta-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-bright);
    line-height: 1.4;
    margin: 0;
    transition: color var(--transition-fast);
  }

  .blog-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-summary {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .summary-prefix {
    color: var(--color-text-dim);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .blog-card:hover .tag {
    color: var(--color-accent);
  }

  /* Read link */
  .card-read {
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
  }

  .read-link {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    transition: color var(--transition-fast);
  }

  .blog-card:hover .read-link {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .card-content {
      padding: var(--space-3);
    }
  }
</style>
