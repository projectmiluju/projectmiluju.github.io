---
interface Props {
  title: string;
  slug: string;
  period: string;
  role: string;
  stack: string[];
  highlights?: string[];
  metrics?: string[];
  cover?: string;
  youtube?: string;
}

const { title, slug, period, role, stack, highlights = [], metrics = [], cover, youtube } = Astro.props;

const getYouTubeId = (id?: string) => {
  if (!id) return null;
  return id.split('?')[0];
};

const displayCover = cover || (youtube ? `https://img.youtube.com/vi/${getYouTubeId(youtube)}/maxresdefault.jpg` : undefined);

// Pad title for consistent display
const paddedSlug = slug.padEnd(24, ' ');
---

<article class="project-card">
  <a href={`/projects/${slug}`} class="card-link">
    <!-- File header line -->
    <div class="card-file-header">
      <span class="file-icon">▶</span>
      <span class="file-name">{slug}/</span>
      <span class="file-period">{period}</span>
    </div>

    <!-- Cover image (optional) -->
    {displayCover && (
      <div class="card-cover">
        <img src={displayCover} alt={`${title} 프로젝트`} loading="lazy" />
        <div class="cover-overlay"></div>
      </div>
    )}

    <!-- Card body -->
    <div class="card-body">
      <h3 class="card-title">{title}</h3>

      <div class="card-role">
        <span class="field-name">role</span>
        <span class="field-sep"> : </span>
        <span class="field-value">{role}</span>
      </div>

      {metrics.length > 0 && (
        <div class="card-metric">
          <span class="metric-icon">↗</span>
          <span class="metric-text">{metrics[0]}</span>
        </div>
      )}

      <div class="card-stack">
        {stack.slice(0, 5).map((tech) => (
          <span class="stack-tag">{tech}</span>
        ))}
        {stack.length > 5 && (
          <span class="stack-more">+{stack.length - 5}</span>
        )}
      </div>
    </div>

    <!-- Footer -->
    <div class="card-file-footer">
      <span class="footer-enter">↵ enter</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* File header */
  .card-file-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .file-icon {
    color: var(--color-accent);
    font-size: var(--text-xs);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .project-card:hover .file-icon {
    transform: translateX(3px);
  }

  .file-name {
    color: var(--color-text-bright);
    font-size: var(--text-xs);
    font-weight: 600;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-period {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* Cover image */
  .card-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-code-bg);
  }

  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow), filter var(--transition-slow);
    filter: grayscale(30%) brightness(0.8);
  }

  .cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(13, 13, 13, 0.8));
  }

  .project-card:hover .card-cover img {
    transform: scale(1.03);
    filter: grayscale(0%) brightness(0.9);
  }

  /* Body */
  .card-body {
    flex: 1;
    padding: var(--space-4) var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-bright);
    line-height: 1.4;
    margin: 0;
    transition: color var(--transition-fast);
  }

  .project-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-role {
    font-size: var(--text-xs);
    line-height: 1.5;
  }

  .field-name {
    color: var(--color-prompt-path);
  }

  .field-sep {
    color: var(--color-text-muted);
  }

  .field-value {
    color: var(--color-text);
  }

  .card-metric {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-accent-light);
    border: 1px solid rgba(0, 255, 65, 0.15);
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .metric-icon {
    font-size: 0.85em;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: auto;
  }

  .stack-tag {
    font-size: var(--text-xs);
    padding: 0.1em 0.45em;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .project-card:hover .stack-tag {
    border-color: rgba(0, 255, 65, 0.2);
    color: var(--color-accent);
    background-color: var(--color-accent-light);
  }

  .stack-more {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding: 0.1em 0.3em;
  }

  /* Footer */
  .card-file-footer {
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
  }

  .footer-enter {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    transition: color var(--transition-fast);
  }

  .project-card:hover .footer-enter {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .card-body {
      padding: var(--space-3);
    }
  }
</style>
