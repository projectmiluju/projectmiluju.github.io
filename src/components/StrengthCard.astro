---
interface Props {
  title: string;
  description: string;
  icon: 'shield' | 'zap' | 'cog';
  evidence?: string;
}

const { title, description, icon, evidence } = Astro.props;

const iconMap = {
  shield: '[RELIABILITY]',
  zap: '[PERFORMANCE]',
  cog: '[AUTOMATION]',
};

const statusLabel = iconMap[icon] || `[${icon.toUpperCase()}]`;
---

<div class="strength-card">
  <div class="card-header">
    <span class="status-label">{statusLabel}</span>
    <span class="status-pass">PASS</span>
  </div>

  <div class="card-body">
    <h3 class="strength-title">
      <span class="check-mark">✓</span>
      {title}
    </h3>
    <p class="strength-desc">{description}</p>

    {evidence && (
      <div class="evidence-block">
        <span class="evidence-prefix">↳ </span>
        <span class="evidence-text">{evidence}</span>
      </div>
    )}
  </div>

  <div class="card-footer">
    <span class="footer-dots">···</span>
  </div>
</div>

<style>
  .strength-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    overflow: hidden;
  }

  .strength-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .status-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .strength-card:hover .status-label {
    color: var(--color-accent);
  }

  .status-pass {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .card-body {
    padding: var(--space-5) var(--space-4);
  }

  .strength-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-bright);
    margin-bottom: var(--space-3);
  }

  .check-mark {
    color: var(--color-accent);
    font-size: var(--text-lg);
    flex-shrink: 0;
  }

  .strength-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    padding-left: calc(var(--space-2) + 1em);
  }

  .evidence-block {
    display: flex;
    gap: 0;
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    background-color: var(--color-accent-light);
    border-left: 2px solid var(--color-accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .evidence-prefix {
    color: var(--color-accent);
    font-size: var(--text-xs);
    flex-shrink: 0;
  }

  .evidence-text {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .card-footer {
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .footer-dots {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.2em;
  }

  @media (max-width: 768px) {
    .card-body {
      padding: var(--space-4);
    }
  }
</style>
